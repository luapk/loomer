# Anthropic (required for storyboard generation and parsing)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (required for reference still + shot generation — Sessions 3-4)
# Get from: aistudio.google.com → Get API key
GOOGLE_AI_API_KEY=...

# Vercel Postgres (required for database)
# Get these from: Vercel dashboard → Storage → your Postgres database → .env.local
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# Vercel Blob (required for storing generated images — Session 3+)
# Get from: Vercel dashboard → Storage → your Blob store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Password gate — set to any string; users enter this to access the app
LOOMER_PASSWORD=your-password-here
